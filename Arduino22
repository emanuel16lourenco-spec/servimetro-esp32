// --- FUNÇÕES DE CORREÇÃO E MEMÓRIA ---
float aplicarCorrecao(float x) {
  int n = 0, indices[4];
  for (int i = 0; i < 4; i++) if (y_real[i] != VALOR_NULO) indices[n++] = i;
  if (n < 2) return x;
  int seg = 0;
  for (int i = 0; i < n - 1; i++) { seg = i; if (x <= x_lido[indices[i+1]]) break; }
  float x0 = x_lido[indices[seg]], y0 = y_real[indices[seg]];
  float x1 = x_lido[indices[seg+1]], y1 = y_real[indices[seg+1]];
  return (abs(x1 - x0) < 0.001) ? x + (y0 - x0) : y0 + (x - x0) * (y1 - y0) / (x1 - x0);
}

void gravarDados() {
  prefs.begin("metrologia", false);
  prefs.putString("senha", senhaMestra);
  for(int i=0; i<4; i++) {
    prefs.putFloat(("x"+String(i)).c_str(), x_lido[i]);
    prefs.putFloat(("y"+String(i)).c_str(), y_real[i]);
  }
  prefs.end();
}

void carregarDados() {
  prefs.begin("metrologia", true);
  senhaMestra = prefs.getString("senha", "1998");
  for(int i=0; i<4; i++) {
    x_lido[i] = prefs.getFloat(("x"+String(i)).c_str(), 0.0);
    y_real[i] = prefs.getFloat(("y"+String(i)).c_str(), VALOR_NULO);
  }
  prefs.end();
}

void resetarCamposAjuste() {
