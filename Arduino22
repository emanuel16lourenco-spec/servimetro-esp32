}

void finalizarClique() {
  while (touchscreen.touched()) { touchscreen.getPoint(); delay(10); }
  delay(150); 
}

// --- INTERFACE GRÁFICA ---
void drawWiFiSignal(int x, int y) {
  int32_t dbm = WiFi.RSSI();
  int bars = (WiFi.status() == WL_CONNECTED) ? (dbm > -50 ? 4 : (dbm > -65 ? 3 : (dbm > -75 ? 2 : (dbm > -85 ? 1 : 0)))) : 0;
  for (int i = 0; i < 4; i++) {
    tft.fillRect(x + (i * 6), y + (10 - (i * 3)), 3, (i * 3) + 3, (i < bars) ? TFT_WHITE : 0x5AEB);
  }
}

void drawHeader() {
  tft.fillRect(0, 0, 320, 40, 0x1A5CFF); 
  tft.setTextColor(TFT_WHITE); tft.drawString("SERVIMETRO", 10, 12, 2);
  
  if (ethernetConectado) {
    tft.fillCircle(250, 20, 5, TFT_GREEN);
    tft.setTextDatum(TR_DATUM); 
    tft.drawString("ETH", 245, 12, 1);
  } else if (WiFi.status() == WL_CONNECTED) {
    tft.fillCircle(305, 20, 5, TFT_GREEN);
    drawWiFiSignal(265, 12);
    tft.setTextDatum(TR_DATUM); tft.drawString(WiFi.SSID().substring(0, 10), 255, 12, 1);
  } else {
    tft.fillCircle(305, 20, 5, TFT_RED);
    tft.setTextDatum(TR_DATUM); tft.drawString("OFFLINE", 290, 12, 1);
  }
  tft.setTextDatum(TL_DATUM);
}

void drawConfigIcon(int centerX, int centerY, int diameter) {
  uint16_t darkGrey = 0x3186; uint16_t blueNuc = 0x1A5CFF; 
  tft.fillCircle(centerX, centerY, (diameter/2)-4, darkGrey);
  for (int i = 0; i < 8; i++) {
    float a1 = (i*45-18)*(PI/180.0), a2 = (i*45+18)*(PI/180.0), a3 = (i*45-10)*(PI/180.0), a4 = (i*45+10)*(PI/180.0);
    int r = (diameter/2)-4;
    tft.fillTriangle(centerX+r*cos(a1), centerY+r*sin(a1), centerX+(r+5)*cos(a3), centerY+(r+5)*sin(a3), centerX+(r+5)*cos(a4), centerY+(r+5)*sin(a4), darkGrey);
    tft.fillTriangle(centerX+r*cos(a1), centerY+r*sin(a1), centerX+(r+5)*cos(a4), centerY+(r+5)*sin(a4), centerX+r*cos(a2), centerY+r*sin(a2), darkGrey);
  }
  tft.fillCircle(centerX, centerY, (diameter/2)-7, darkGrey); tft.fillCircle(centerX, centerY, (diameter/2)-10, blueNuc); 
}

