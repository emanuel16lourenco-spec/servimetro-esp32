// ========== TASK ETHERNET (NÃO BLOQUEIA SPI) ==========
void taskEthernetLoop(void *parameter) {
  Serial.println("\n--- Inicializando Ethernet em background ---");
  
  Ethernet.init(W5500_CS);
  Ethernet.begin(mac, ip_esp);
  
  delay(2000);
  
  Serial.print("✅ Ethernet IP: ");
  Serial.println(Ethernet.localIP());
  
  // Enviar setpoint inicial
  if (client.connect(ip_additel, 8000)) {
    Serial.println("✅ Conectado ao Additel!");
    client.print("SOURce:TEMPerature:TARGet 50,1001\r\n");
    delay(200);
    client.stop();
    Serial.println("✅ Setpoint 50°C enviado!");
    ethernetConectado = true;
  } else {
    Serial.println("❌ Falha ao conectar ao Additel");
  }
  
  // Loop infinito na task
  unsigned long ultimaLeitura = 0;
  while(1) {
    vTaskDelay(100 / portTICK_PERIOD_MS);  // Não bloqueia
    
    // Leitura periódica (30 segundos)
    if (millis() - ultimaLeitura >= intervalo) {
      if (client.connect(ip_additel, 8000)) {
        client.print("MEASure:SCALar:CONTrol?\r\n");
        delay(200);
        if (client.available()) {
          String resposta = "";
          while (client.available()) {
            resposta += (char)client.read();
          }
          Serial.print("Status Additel: ");
          Serial.println(resposta);
        }
        client.stop();
      }
      ultimaLeitura = millis();
    }
  }
}
